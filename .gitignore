# Git ignore — file dan folder yang TIDAK boleh di-commit ke git

# Environment variables — berisi API key rahasia
backend/.env
*.env

# Flutter build output
flutter_app/build/
flutter_app/.dart_tool/
flutter_app/.flutter-plugins
flutter_app/.flutter-plugins-dependencies

# Node modules
backend/node_modules/

# Flutter packages
flutter_app/.packages

# Android build
flutter_app/android/.gradle/
flutter_app/android/app/release/

# Windows build
flutter_app/windows/flutter/

# IDE
.vscode/
.idea/
*.iml

# OS files
.DS_Store
Thumbs.db

# Log files
*.log
