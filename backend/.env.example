# ============================================================
# Environment Variables untuk Personal AI Backend
# Salin file ini menjadi ".env" dan isi nilainya
# JANGAN commit file .env ke git!
# ============================================================

# --- Supabase ---
# Ambil dari: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# JWT Secret untuk verifikasi token dari Flutter app
# Ambil dari: Supabase Dashboard → Project Settings → API → JWT Settings
SUPABASE_JWT_SECRET=your-jwt-secret-here

# --- LLM Provider ---
# Ganti ke 'claude' untuk pakai Anthropic, tanpa ubah kode lain
LLM_PROVIDER=gemini

# Gemini API Key
# Ambil dari: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Claude API Key (isi kalau mau pakai Claude)
# Ambil dari: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# --- Tavily Web Search ---
# Ambil dari: https://app.tavily.com/
TAVILY_API_KEY=your-tavily-api-key-here

# --- Server ---
PORT=3000

# Nama model yang dipakai (bisa diubah sesuai kebutuhan)
GEMINI_MODEL=gemini-1.5-flash
CLAUDE_MODEL=claude-3-5-sonnet-20241022
